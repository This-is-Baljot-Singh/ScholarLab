# ScholarLab Backend Environment Configuration
# Copy to .env and fill in actual values

# ============================================================================
# ENVIRONMENT PROFILE
# ============================================================================
# Options: dev, staging, pilot, production
SCHOLARLAB_ENV=dev

# ============================================================================
# DATABASE
# ============================================================================
# MongoDB connection URL
# Local dev (no auth):
MONGODB_URL=mongodb://localhost:27017
# Docker / authenticated (uncomment when using docker-compose):
# MONGODB_URL=mongodb://admin:admin@mongodb:27017/scholarlab?authSource=admin
# Database name
MONGODB_DATABASE=scholarlab_dev

# ============================================================================
# AUTHENTICATION
# ============================================================================
# JWT secret key (rotate quarterly in production)
SECRET_KEY=your-super-secret-jwt-key-change-in-production
# JWT algorithm
ALGORITHM=HS256
# Token expiry times
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# WebAuthn configuration
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ScholarLab
WEBAUTHN_ORIGIN=http://localhost:5173

# ============================================================================
# ZERO-TRUST ATTENDANCE
# ============================================================================
# Confidence thresholds (0.0-1.0)
BIOMETRIC_CONFIDENCE_THRESHOLD=0.95
# Spatial accuracy in meters
SPATIAL_ACCURACY_THRESHOLD_METERS=10.0
# Challenge expiry in seconds
CHALLENGE_EXPIRY_SECONDS=300

# ============================================================================
# JOB QUEUE (Celery + Redis)
# ============================================================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0
# Celery broker URL
CELERY_BROKER_URL=redis://localhost:6379/0
# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================================
# LOCAL INFERENCE (Ollama)
# ============================================================================
# Ollama base URL for local audio transcription
OLLAMA_BASE_URL=http://localhost:11434
# Ollama model for transcription
OLLAMA_TRANSCRIPTION_MODEL=whisper
# Ollama model for LLM tasks
OLLAMA_LLM_MODEL=llama2

# ============================================================================
# AUDIT LOGGING
# ============================================================================
# Log all requests
LOG_ALL_REQUESTS=true
# Log all state changes
LOG_ALL_STATE_CHANGES=true
# Sign audit logs (production)
AUDIT_LOG_SIGNING=false
# Audit log collection name
AUDIT_LOG_COLLECTION=audit_logs

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enforce local inference only (no cloud APIs)
ENFORCE_LOCAL_INFERENCE=true
# Disable all cloud APIs
DISABLE_CLOUD_APIS=true
# Strict input validation
STRICT_INPUT_VALIDATION=true
# Strict output validation
STRICT_OUTPUT_VALIDATION=false
# Enable debug endpoints
ENABLE_DEBUG_ENDPOINTS=true
# Enable seed data endpoints
ENABLE_SEED_DATA_ENDPOINTS=true

# ============================================================================
# ON-PREMISES OBJECT STORE (Replaces AWS S3 — stays within campus trust boundary)
# ============================================================================
# MinIO endpoint (docker: http://minio:9000, local: http://localhost:9000)
MINIO_ENDPOINT=http://localhost:9000
# MinIO credentials (change in production)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Bucket for ephemeral classroom audio (auto-created on startup)
MINIO_BUCKET_NAME=scholarlab-audio

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# JSON logging format
JSON_LOGGING=true

# ============================================================================
# CORS
# ============================================================================
# Allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================================================
# OPTIONAL: INSTITUTIONAL DATA
# ============================================================================
# Institution name
INSTITUTION_NAME=Example University
# Institution ID
INSTITUTION_ID=inst_001
